<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardReminder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:strokeColor="@color/beige_dark"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp"
        android:background="@color/beige">

        <TextView
            android:id="@+id/tvReminderCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Health"
            android:textColor="@color/moss_green"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvReminderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Drink water"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvReminderDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stay hydrated today"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tvReminderMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to mark as done"
            android:textColor="@color/dark_green"
            android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>