<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/card_soft_white"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvHistoryDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wed, 15 Apr"
        android:textColor="#1F1A17"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvHistoryTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="10:30 PM → 6:45 AM"
        android:textColor="#6F5B5B"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvHistoryDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="8h 15m • Good"
        android:textColor="#4A7C59"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvHistoryNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="No note added"
        android:textColor="#8A817C"
        android:textSize="13sp" />
</LinearLayout>